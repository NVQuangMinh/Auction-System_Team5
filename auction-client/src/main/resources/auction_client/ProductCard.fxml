<VBox alignment="TOP_CENTER" prefHeight="350.0" prefWidth="240.0" style="-fx-background-color: #f0f0f0; -fx-background-radius: 15; -fx-border-color: #dcdcdc; -fx-border-width: 2; -fx-border-radius: 15;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
