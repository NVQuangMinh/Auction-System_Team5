            <Label prefHeight="46.0" prefWidth="317.0" style="-fx-font-size: 16; -fx-font-weight: bold;" text=" Item Name" textFill="#fc5421cc">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Label alignment="CENTER_RIGHT" prefHeight="59.0" prefWidth="231.0" style="-fx-font-size: 16; -fx-font-weight: Bold;" text="STATE" textAlignment="CENTER" textFill="RED">
