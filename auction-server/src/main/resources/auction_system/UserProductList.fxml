<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction_system.controllers.UserProductListController">
   <top>
       <fx:include fx:id="menuBar" source="WebMenuBar.fxml" />
   </top>
   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" BorderPane.alignment="CENTER">
         <content>
            <VBox alignment="TOP_CENTER">
               <children>
                  <HBox alignment="CENTER" prefHeight="124.0" prefWidth="1198.0">
                     <children>
                        <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-label-padding: 1 31.5 1 31.5; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.4), 15, 0, 0, 5);" text="YOUR LISTING" />
                        <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleUserAddItem" style="-fx-background-color: #138EFF; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-label-padding: 1 20 1 20; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.4), 15, 0, 0, 5);" text="+ ADD NEW ITEM" textFill="WHITE" />
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="20.0" left="90.0" right="90.0" top="20.0" />
                     </padding>
                  </HBox>
                  <FlowPane hgap="20.0" vgap="20.0">
                     <padding>
                        <Insets left="60.0" right="60.0" />
                     </padding>
                  </FlowPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
