<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="background" prefHeight="600.0" prefWidth="1066.0" style="-fx-background-color: #f6f8ef;" stylesheets="@Background.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction_system.controllers.SignInController">
   <children>
      <ImageView layoutX="-14.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <image>
            <Image url="@images/1378262.png" />
         </image>
      </ImageView>
      <HBox alignment="CENTER_LEFT" fillHeight="false" layoutX="7.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane style="-fx-background-radius: 30;">
               <children>
                  <VBox alignment="CENTER" prefHeight="530.0" prefWidth="422.0" spacing="15.0" style="-fx-background-color: #138eff; -fx-background-radius: 30;">
                     <children>
                        <ImageView fitHeight="143.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/Auction-System.png" />
                           </image>
                           <VBox.margin>
                              <Insets top="3.0" />
                           </VBox.margin>
                        </ImageView>
                        <HBox alignment="CENTER" fillHeight="false" prefHeight="55.0" prefWidth="422.0" spacing="50.0">
                           <children>
                              <Button fx:id="signInButton" maxHeight="31.0" maxWidth="115.0" mnemonicParsing="false" onAction="#switchToSignInScene" prefHeight="31.0" prefWidth="115.0" style="-fx-background-color: white; -fx-background-radius: 500;" text="Sign In">
                                 <font>
                                    <Font name="System Bold" size="15.0" />
                                 </font>
                              </Button>
                              <Button fx:id="signUpButton" alignment="CENTER" maxHeight="31.0" maxWidth="115.0" mnemonicParsing="false" onAction="#switchToSignUpScene" prefHeight="31.0" prefWidth="115.0" style="-fx-background-color: transparent; -fx-background-radius: 500;" text="Sign up" textFill="WHITE">
                                 <font>
                                    <Font name="System Bold" size="15.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                        <VBox alignment="TOP_CENTER" fillWidth="false" spacing="20.0">
                           <children>
                              <TextField fx:id="username" maxWidth="256.0" prefHeight="31.0" prefWidth="255.0" promptText="USERNAME" style="-fx-background-color: white;">
                                 <font>
                                    <Font size="15.0" />
                                 </font>
                              </TextField>
                              <PasswordField fx:id="password" maxWidth="255.0" prefHeight="31.0" prefWidth="255.0" promptText="PASSWORD" style="-fx-background-color: white;">
                                 <font>
                                    <Font size="15.0" />
                                 </font>
                              </PasswordField>
                              <Region prefHeight="23.0" prefWidth="422.0">
                                 <VBox.margin>
                                    <Insets top="18.0" />
                                 </VBox.margin>
                              </Region>
                              <Button fx:id="loginButton" mnemonicParsing="false" onAction="#switchToMainScene" prefHeight="34.0" prefWidth="120.0" style="-fx-background-color: white; -fx-background-radius: 500;" text="LOGIN">
                                 <font>
                                    <Font name="System Bold" size="15.0" />
                                 </font>
                              </Button>
                           </children>
                           <VBox.margin>
                              <Insets top="1.0" />
                           </VBox.margin>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <padding>
            <Insets left="200.0" />
         </padding>
      </HBox>
   </children>
</AnchorPane>
